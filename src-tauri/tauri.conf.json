{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Train Depot",
  "version": "1.4.1",
  "identifier": "uk.co.tinkerforce.traindepot",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:8005"
  },
  "app": {
    "windows": [
      {
        "title": "Train Depot",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": ["$APPDATA/**", "$HOME/.local/share/train-depot/uploads/**", "$HOME/Library/Application Support/train-depot/uploads/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
